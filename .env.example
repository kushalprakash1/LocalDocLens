# LocalDocLens environment example
# Copy this to .env only if needed.
# Do NOT commit your real .env file.

# Local-only server defaults
LOCALDOCLENS_HOST=127.0.0.1
LOCALDOCLENS_PORT=8000

# Ollama local model
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b

# Privacy:
# LocalDocLens is designed to run locally.
# User PDFs, extracted text, SQLite DBs, cache, and training examples should stay on the user's machine.
LOCALDOCLENS_TELEMETRY=off
